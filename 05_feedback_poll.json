{
  "poll_id": "feedback_poll_v1",
  "version": "1.0",
  "name": "Feedback Poll — Post-Program",
  "description": "Évaluation satisfaction, collecte feedback, redirection vers nouveau programme",
  "trigger": "on_program_completion",
  "total_questions": 3,
  "scoring_formula": "(score_q1 + score_q2) / 2",
  "questions": [
    {
      "id": "fp_q1",
      "question_number": 1,
      "text": "Êtes-vous satisfait(e) de vos résultats par rapport à vos objectifs initiaux ?",
      "type": "scale_1_5",
      "stores_as": "score_q1",
      "options": [
        {"value": 1, "label": "⭐ Très insatisfait(e)", "sublabel": "Je n'ai pas atteint mes objectifs"},
        {"value": 2, "label": "⭐⭐ Insatisfait(e)", "sublabel": "Quelques résultats mais insuffisants"},
        {"value": 3, "label": "⭐⭐⭐ Satisfait(e)", "sublabel": "Résultats corrects mais aurais aimé plus"},
        {"value": 4, "label": "⭐⭐⭐⭐ Très satisfait(e)", "sublabel": "Excellents résultats"},
        {"value": 5, "label": "⭐⭐⭐⭐⭐ Extrêmement satisfait(e)", "sublabel": "Dépassé mes attentes"}
      ]
    },
    {
      "id": "fp_q2",
      "question_number": 2,
      "text": "Quel aspect du program a été le plus challenging ?",
      "type": "qcm_with_subscale",
      "stores_as": "score_q2",
      "stores_factor_as": "q2_factor",
      "scoring_rule": "if F selected → score=5 | else score = 5 - sub_scale_value",
      "options": [
        {
          "id": "fp_q2_a",
          "value": "difficulty",
          "label": "A) Difficulté physique",
          "sublabel": "Intensité trop haute/basse",
          "has_subscale": true,
          "maps_to_variant": ["intensity_down"]
        },
        {
          "id": "fp_q2_b",
          "value": "time",
          "label": "B) Temps disponible",
          "sublabel": "Séances trop longues/courtes",
          "has_subscale": true,
          "maps_to_variant": ["frequency_down"]
        },
        {
          "id": "fp_q2_c",
          "value": "boredom",
          "label": "C) Ennui",
          "sublabel": "Exercices répétitifs, manque de variation",
          "has_subscale": true,
          "maps_to_variant": ["exercise_variation", "split_variation", "intensity_up", "frequency_up"],
          "triggers_alternative_program_pitch": true
        },
        {
          "id": "fp_q2_d",
          "value": "equipment",
          "label": "D) Équipement",
          "sublabel": "Accès insuffisant à l'équipement",
          "has_subscale": true,
          "maps_to_variant": ["exercise_variation"],
          "fallback_to_bodyweight": true
        },
        {
          "id": "fp_q2_e",
          "value": "recovery",
          "label": "E) Récupération",
          "sublabel": "Fatigue, manque de repos",
          "has_subscale": true,
          "maps_to_variant": ["frequency_down", "intensity_down"]
        },
        {
          "id": "fp_q2_f",
          "value": "nothing",
          "label": "F) Rien",
          "sublabel": "Tout s'est bien passé !",
          "has_subscale": false,
          "fixed_score": 5
        }
      ],
      "subscale": {
        "text": "À quel point ce facteur a-t-il affecté votre satisfaction ?",
        "options": [
          {"value": 1, "label": "Pas du tout", "sublabel": "Mineur"},
          {"value": 2, "label": "Un peu", "sublabel": "Modéré"},
          {"value": 3, "label": "Beaucoup", "sublabel": "Majeur"}
        ]
      }
    },
    {
      "id": "fp_q3",
      "question_number": 3,
      "text": "Compte tenu de vos résultats, quel est votre objectif principal pour le prochain cycle ?",
      "type": "single_choice",
      "stores_as": "q3_new_objective",
      "note": "Identique à Q3 du questionnaire initial",
      "options": [
        {
          "id": "fp_q3_a",
          "value": "aesthetics",
          "label": "A) Esthétique",
          "sublabel": "Continuer à construire du muscle, améliorer l'apparence",
          "maps_to_program_id": "program_muscle_building"
        },
        {
          "id": "fp_q3_b",
          "value": "strength",
          "label": "B) Force",
          "sublabel": "Augmenter ma force maximale",
          "maps_to_program_id": "program_strength"
        },
        {
          "id": "fp_q3_c",
          "value": "performance",
          "label": "C) Athlétique",
          "sublabel": "Améliorer ma performance, explosivité, cardio",
          "maps_to_program_id": "program_athletic"
        },
        {
          "id": "fp_q3_d",
          "value": "efficiency",
          "label": "D) Efficacité",
          "sublabel": "Rester efficace avec le temps limité",
          "maps_to_program_id": "program_lactate"
        },
        {
          "id": "fp_q3_e",
          "value": "complete",
          "label": "E) Complet",
          "sublabel": "Développer tous les aspects (force, muscle, cardio, mobilité)",
          "maps_to_program_id": null,
          "maps_to_persona": "SAV"
        }
      ]
    }
  ],
  "redirection_engine": {
    "score_formula": "(score_q1 + score_q2) / 2",
    "cases": [
      {
        "id": "case_very_satisfied",
        "condition": "score_global >= 4",
        "label": "Très Satisfait",
        "action": "new_primary_program",
        "logic": "Lookup program mapped to q3_new_objective for current persona",
        "message_template": "Bravo ! Vous avez atteint vos objectifs. Vous êtes prêt(e) pour {program_name} !",
        "coach_notification": false
      },
      {
        "id": "case_moderate",
        "condition": "score_global >= 2.5 AND score_global < 4",
        "label": "Satisfait Moyen",
        "action": "same_program_with_variants",
        "logic": "Apply variant based on q2_factor, suggest alternative if boredom",
        "message_template": "Continuons avec des ajustements pour mieux correspondre à vos besoins.",
        "coach_notification": false,
        "suggest_alternative_if": "q2_factor = 'boredom'"
      },
      {
        "id": "case_unsatisfied",
        "condition": "score_global < 2.5",
        "label": "Insatisfait",
        "action": "same_program_with_variants_and_support",
        "logic": "Apply variant + trigger coach notification email",
        "message_template": "Nous avons remarqué des difficultés. Nous ajustons votre programme et notre équipe vous contactera.",
        "coach_notification": true,
        "coach_email_trigger": true
      }
    ]
  }
}
